<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 120" width="320" height="120">
  <defs>
    <linearGradient id="hexGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a5f2a;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#2d8a4e;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f4a020;stop-opacity:1" />
    </linearGradient>
    
    <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
      <feMerge>
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
    
    <style>
      .hexagon { animation: rotate 25s linear infinite; transform-origin: 45px 45px; }
      @keyframes rotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
      .sun-rays { animation: pulse 2.5s ease-in-out infinite; }
      @keyframes pulse { 0%, 100% { opacity: 0.7; transform: scale(1); } 50% { opacity: 1; transform: scale(1.15); } }
    </style>
  </defs>
  
  <g transform="translate(10, 15)">
    <g class="hexagon">
      <polygon points="45,5 82.5,26.25 82.5,68.75 45,90 7.5,68.75 7.5,26.25" fill="url(#hexGradient)" stroke="#1a5f2a" stroke-width="2" filter="url(#glow)"/>
    </g>
    <polygon points="45,22 63.5,32.75 63.5,54.25 45,65 26.5,54.25 26.5,32.75" fill="#ffffff" opacity="0.95"/>
    <g transform="translate(45, 45)">
      <circle cx="0" cy="0" r="8" fill="#f4a020" class="sun-rays"/>
      <g stroke="#f4a020" stroke-width="2" stroke-linecap="round" class="sun-rays">
        <line x1="0" y1="-14" x2="0" y2="-18"/>
        <line x1="10" y1="-7" x2="13" y2="-9"/>
        <line x1="10" y1="7" x2="13" y2="9"/>
        <line x1="0" y1="14" x2="0" y2="18"/>
        <line x1="-10" y1="7" x2="-13" y2="9"/>
        <line x1="-10" y1="-7" x2="-13" y2="-9"/>
      </g>
    </g>
  </g>
  
  <g transform="translate(105, 25)">
    <text x="0" y="35" font-family="'Poppins', Arial, sans-serif" font-size="42" font-weight="800" fill="#1a5f2a" letter-spacing="4">GESPA</text>
    <line x1="0" y1="42" x2="180" y2="42" stroke="#f4a020" stroke-width="2.5" stroke-linecap="round"/>
    <text x="0" y="58" font-family="'Inter', Arial, sans-serif" font-size="11" font-weight="600" fill="#2d8a4e" letter-spacing="2.5">GÜNEŞ ENERJİ SİSTEMLERİ &amp; PAZARLAMA</text>
    <text x="0" y="75" font-family="'Inter', Arial, sans-serif" font-size="9" font-weight="500" fill="#6b7280" letter-spacing="1.5">GESPA ENERJİ SAN.TİC.LTD.ŞTİ.</text>
  </g>
</svg>
